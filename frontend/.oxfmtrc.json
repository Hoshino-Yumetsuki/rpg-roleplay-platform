{
  "indent": { "type": "space", "width": 2 },
  "lineWidth": 80,
  "lineEnding": "lf",
  "semicolons": "as-needed",
  "singleQuote": true,
  "jsxQuoteStyle": "double",
  "trailingCommas": "none",
  "arrowParentheses": "always",
  "bracketSpacing": true,
  "attributePosition": "auto",
  "ignorePatterns": ["*.md"]
}
